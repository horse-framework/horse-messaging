        <TargetFramework>net10.0</TargetFramework>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <Nullable>enable</Nullable>
        <!-- BenchmarkDotNet requires Release build for meaningful results -->
        <Optimize>true</Optimize>
